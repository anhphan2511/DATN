@{
    ViewData["Title"] = "Trang chu";
}

<div class="min-h-screen bg-gradient-to-b from-slate-50 via-white to-emerald-50/40 text-slate-900">
    <section class="relative overflow-hidden rounded-3xl bg-slate-900 px-6 py-14 md:px-12">
        <div class="absolute -right-16 -top-16 h-56 w-56 rounded-full bg-brand-500/30 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-16 h-60 w-60 rounded-full bg-cyan-400/20 blur-3xl"></div>

        <div class="relative z-10 grid gap-10 md:grid-cols-2 md:items-center">
            <div>
                <p class="mb-4 inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">
                    Flash Sale 50%
                </p>
                <h1 class="text-3xl font-black leading-tight text-white md:text-5xl">
                    Mua sam thong minh,
                    <span class="text-brand-100">nhan uu dai moi ngay</span>
                </h1>
                <p class="mt-4 max-w-xl text-sm text-slate-200 md:text-base">
                    Hang ngan san pham chinh hang, giao nhanh 2h noi thanh va chinh sach doi tra 30 ngay.
                    Bat dau don hang dau tien voi ma giam gia danh rieng cho ban.
                </p>
                <div class="mt-8 flex flex-wrap gap-3">
                    <a href="#featured" class="rounded-xl bg-brand-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600">Mua ngay</a>
                    <a href="#categories" class="rounded-xl border border-white/30 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Xem danh muc</a>
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl bg-white/10 p-5 backdrop-blur">
                    <p class="text-xs uppercase tracking-wide text-slate-300">Don hang hom nay</p>
                    <p class="mt-2 text-3xl font-extrabold text-white">1,284</p>
                    <p class="mt-1 text-xs text-emerald-200">Tang 18% so voi hom qua</p>
                </div>
                <div class="rounded-2xl bg-white p-5">
                    <p class="text-xs uppercase tracking-wide text-slate-500">Khach hang hai long</p>
                    <p class="mt-2 text-3xl font-extrabold text-slate-900">98.7%</p>
                    <p class="mt-1 text-xs text-slate-500">Duoc danh gia 4.9/5</p>
                </div>
                <div class="rounded-2xl bg-white p-5 sm:col-span-2">
                    <p class="text-xs uppercase tracking-wide text-slate-500">Uu dai noi bat</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">Mien phi giao hang</span>
                        <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">Hoan xu 5%</span>
                        <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700">Tra gop 0%</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="categories" class="mt-10">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-2xl font-bold">Danh muc pho bien</h2>
            <a href="#" class="text-sm font-semibold text-brand-700 hover:text-brand-600">Xem tat ca</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">Mobile</p>
                <h3 class="mt-3 font-bold">Dien thoai</h3>
                <p class="mt-1 text-sm text-slate-500">Tu iPhone den Android cao cap</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">Laptop</p>
                <h3 class="mt-3 font-bold">Laptop</h3>
                <p class="mt-1 text-sm text-slate-500">May tinh hoc tap va lam viec</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">Audio</p>
                <h3 class="mt-3 font-bold">Phu kien</h3>
                <p class="mt-1 text-sm text-slate-500">Tai nghe, ban phim, sac nhanh</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-700">Wearable</p>
                <h3 class="mt-3 font-bold">Do thong minh</h3>
                <p class="mt-1 text-sm text-slate-500">Dong ho, thiet bi theo doi suc khoe</p>
            </article>
        </div>
    </section>

    <section id="featured" class="mt-10">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-2xl font-bold">San pham noi bat</h2>
            <a href="#" class="text-sm font-semibold text-brand-700 hover:text-brand-600">Xem them</a>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="rounded-xl bg-slate-100 p-8 text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Smartphone</div>
                <h3 class="mt-4 font-semibold">NovaPhone X Pro</h3>
                <p class="mt-1 text-sm text-slate-500">Chip A18, camera 108MP</p>
                <div class="mt-3 flex items-center justify-between">
                    <p class="text-lg font-bold text-brand-700">19.990.000 VND</p>
                    <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">Them gio</button>
                </div>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="rounded-xl bg-slate-100 p-8 text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Laptop</div>
                <h3 class="mt-4 font-semibold">ZenBook Air 14</h3>
                <p class="mt-1 text-sm text-slate-500">Intel Ultra 7, RAM 16GB</p>
                <div class="mt-3 flex items-center justify-between">
                    <p class="text-lg font-bold text-brand-700">24.490.000 VND</p>
                    <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">Them gio</button>
                </div>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="rounded-xl bg-slate-100 p-8 text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Headphone</div>
                <h3 class="mt-4 font-semibold">SonicBuds ANC</h3>
                <p class="mt-1 text-sm text-slate-500">Khử ồn chủ động thế hệ mới</p>
                <div class="mt-3 flex items-center justify-between">
                    <p class="text-lg font-bold text-brand-700">2.390.000 VND</p>
                    <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">Them gio</button>
                </div>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="rounded-xl bg-slate-100 p-8 text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Smartwatch</div>
                <h3 class="mt-4 font-semibold">FitWave Watch S</h3>
                <p class="mt-1 text-sm text-slate-500">Theo doi suc khoe 24/7</p>
                <div class="mt-3 flex items-center justify-between">
                    <p class="text-lg font-bold text-brand-700">3.190.000 VND</p>
                    <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white">Them gio</button>
                </div>
            </article>
        </div>
    </section>

    <section class="mt-10 grid gap-4 rounded-3xl bg-white p-6 shadow-sm md:grid-cols-3 md:items-center">
        <div>
            <p class="text-sm font-semibold uppercase tracking-wider text-brand-700">Thanh vien moi</p>
            <h3 class="mt-2 text-2xl font-extrabold">Nhan voucher 200.000 VND</h3>
            <p class="mt-2 text-sm text-slate-500">Dang ky tai khoan ngay hom nay de nhan uu dai va cap nhat khuyen mai doc quyen.</p>
        </div>
        <div class="md:col-span-2">
            <form class="flex flex-col gap-3 sm:flex-row">
                <input type="email" placeholder="Nhap email cua ban" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none ring-brand-500 transition focus:ring" />
                <button type="button" class="rounded-xl bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-600">Dang ky ngay</button>
            </form>
        </div>
    </section>
</div>

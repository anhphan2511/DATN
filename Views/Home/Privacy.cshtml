@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="space-y-6">
    @await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
    {
        Eyebrow = "Bảo mật",
        Title = "Chính sách bảo mật",
        Description = "DATN Wear cam kết bảo vệ thông tin cá nhân và minh bạch cách dữ liệu được sử dụng trong quá trình mua sắm."
    })

    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
        <div class="max-w-3xl space-y-5 text-sm leading-7 text-slate-600 sm:text-base">
            <p>
                Chúng tôi thu thập những thông tin cần thiết để xử lý đơn hàng, giao hàng, hỗ trợ đổi trả và cải thiện trải nghiệm mua sắm trên website.
            </p>
            <p>
                Thông tin cá nhân không được chia sẻ cho bên thứ ba nếu không có sự đồng ý của bạn, trừ các trường hợp phải thực hiện theo yêu cầu của cơ quan có thẩm quyền.
            </p>
            <p>
                Bạn có thể liên hệ bộ phận hỗ trợ để yêu cầu kiểm tra, cập nhật hoặc xóa thông tin cá nhân theo quy định hiện hành.
            </p>
        </div>
    </section>
</div>

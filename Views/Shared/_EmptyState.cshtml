@model EmptyStateViewModel

<section class="rounded-3xl border border-dashed border-slate-300 bg-white/70 p-8 text-center">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-xl font-black text-brand-700">D</div>
    <h2 class="mt-4 text-xl font-black text-slate-950">@Model.Title</h2>
    <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-slate-500">@Model.Description</p>
    @if (!string.IsNullOrWhiteSpace(Model.ActionText) && !string.IsNullOrWhiteSpace(Model.ActionHref))
    {
        <a href="@Model.ActionHref" class="mt-5 inline-flex rounded-full bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-brand-700">@Model.ActionText</a>
    }
</section>

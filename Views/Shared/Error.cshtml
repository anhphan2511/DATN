@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="space-y-6">
    @await Html.PartialAsync("_PageHeader", new PageHeaderViewModel
    {
        Eyebrow = "Cảnh báo hệ thống",
        Title = "Đã xảy ra lỗi trong quá trình xử lý yêu cầu.",
        Description = "Vui lòng thử tải lại trang sau ít phút. Nếu lỗi vẫn tiếp diễn, bạn có thể liên hệ bộ phận hỗ trợ để được kiểm tra nhanh hơn."
    })

    <section class="rounded-3xl border border-red-100 bg-white p-6 shadow-sm sm:p-10">
        @if (Model.ShowRequestId)
        {
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <span class="font-semibold">Request ID:</span>
                <code class="rounded bg-white px-2 py-1 text-xs">@Model.RequestId</code>
            </div>
        }

        <div class="mt-5 rounded-2xl border border-amber-100 bg-amber-50 px-4 py-4 text-sm leading-7 text-amber-800">
            <p><span class="font-semibold">Lưu ý cho môi trường Development:</span> chỉ bật chế độ này khi debug tại máy local.</p>
            <p class="mt-2">Không nên để <code class="rounded bg-amber-100 px-1.5 py-0.5">ASPNETCORE_ENVIRONMENT=Development</code> trên môi trường production vì có thể lộ thông tin nhạy cảm.</p>
        </div>
    </section>
</div>

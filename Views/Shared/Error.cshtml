@model ErrorViewModel
@{
    ViewData["Title"] = "Loi he thong";
}

<section class="rounded-3xl border border-red-100 bg-white p-6 shadow-sm sm:p-10">
    <p class="inline-flex rounded-full bg-red-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-red-600">System alert</p>
    <h1 class="mt-4 text-3xl font-extrabold text-red-600">Da xay ra loi trong qua trinh xu ly yeu cau.</h1>
    <p class="mt-3 text-sm leading-7 text-slate-600 sm:text-base">
        Vui long thu tai lai trang sau it phut. Neu loi van tiep dien, ban co the lien he bo phan ho tro de duoc kiem tra nhanh hon.
    </p>

    @if (Model.ShowRequestId)
    {
        <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
            <span class="font-semibold">Request ID:</span>
            <code class="rounded bg-white px-2 py-1 text-xs">@Model.RequestId</code>
        </div>
    }

    <div class="mt-6 rounded-2xl border border-amber-100 bg-amber-50 px-4 py-4 text-sm leading-7 text-amber-800">
        <p><span class="font-semibold">Luu y cho moi truong Development:</span> chi bat che do nay khi debug tai may local.</p>
        <p class="mt-2">Khong nen de <code class="rounded bg-amber-100 px-1.5 py-0.5">ASPNETCORE_ENVIRONMENT=Development</code> tren moi truong production vi co the lo thong tin nhay cam.</p>
    </div>
</section>

@model PageHeaderViewModel

<header class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
    <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-700">@Model.Eyebrow</p>
    <h1 class="mt-3 max-w-3xl text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">@Model.Title</h1>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600 sm:text-base">@Model.Description</p>
    }
</header>

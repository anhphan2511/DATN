@model ProductCardViewModel

<article class="group rounded-3xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
    <div class="relative flex h-56 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-slate-100 via-white to-brand-50 text-center">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
        }
        @if (!string.IsNullOrWhiteSpace(Model.Badge))
        {
            <span class="absolute left-3 top-3 rounded-full bg-slate-950 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">@Model.Badge</span>
        }
        @if (string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <span class="text-xs font-black uppercase tracking-[0.28em] text-slate-400">@Model.ImageLabel</span>
        }
    </div>
    <div class="mt-4">
        <h3 class="font-black text-slate-950">@Model.Name</h3>
        <p class="mt-1 text-sm leading-6 text-slate-500">@Model.Description</p>
    </div>
    <div class="mt-4 flex items-center justify-between gap-3">
        <div>
            <p class="text-lg font-black text-brand-700">@Model.Price</p>
            @if (!string.IsNullOrWhiteSpace(Model.OriginalPrice))
            {
                <p class="text-sm text-slate-400 line-through">@Model.OriginalPrice</p>
            }
        </div>
        <button type="button" class="rounded-full bg-slate-950 px-4 py-2 text-sm font-bold text-white transition hover:bg-brand-700">Thêm giỏ</button>
    </div>
</article>

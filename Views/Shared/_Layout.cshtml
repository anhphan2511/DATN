<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DATN</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="font-sans text-slate-800 antialiased">
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_right,_rgba(20,184,106,0.14),_transparent_38%),linear-gradient(to_bottom,_#f8fafc,_#f1f5f9_36%,_#ffffff)]">
        @await Html.PartialAsync("_Header")

        <main role="main" class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            @RenderBody()
        </main>

        @await Html.PartialAsync("_Footer")
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model SectionHeaderViewModel

<div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
        <h2 class="text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">@Model.Title</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">@Model.Description</p>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.ActionText) && !string.IsNullOrWhiteSpace(Model.ActionHref))
    {
        <a href="@Model.ActionHref" class="text-sm font-bold text-brand-700 transition hover:text-brand-600">@Model.ActionText</a>
    }
</div>

@model AccountDetailViewModel

@{
    ViewData["Title"] = "Chi tiết tài khoản";

    var isAdmin = Model.Role.Equals("admin", StringComparison.OrdinalIgnoreCase);
    var roleBadgeClass = isAdmin
        ? "bg-slate-950 text-white"
        : "bg-brand-50 text-brand-700";
}

<div class="space-y-8">
    <section class="relative overflow-hidden rounded-[2.5rem] bg-slate-950 p-6 text-white shadow-2xl sm:p-8 lg:p-10">
        <div class="absolute -right-24 -top-24 h-80 w-80 rounded-full bg-brand-500/30 blur-3xl"></div>
        <div class="absolute -bottom-28 left-12 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
            <div>
                <span class="inline-flex rounded-full px-4 py-2 text-xs font-black uppercase tracking-[0.24em] @roleBadgeClass">@Model.RoleLabel</span>
                <h1 class="mt-5 text-4xl font-black tracking-tight sm:text-5xl">@Model.FullName</h1>
                <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
                    Tài khoản demo dùng để minh họa thông tin người dùng, phân quyền và hoạt động gần đây trong hệ thống DATN Wear.
                </p>
            </div>
            <div class="rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur">
                <p class="text-xs font-black uppercase tracking-[0.24em] text-brand-100">Mã tài khoản</p>
                <p class="mt-3 text-3xl font-black">@Model.Id</p>
                <p class="mt-2 text-sm text-slate-300">@Model.Status</p>
            </div>
        </div>
    </section>

    <section class="grid gap-5 lg:grid-cols-3">
        <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Thông tin cá nhân</p>
                    <h2 class="mt-2 text-2xl font-black text-slate-950">Hồ sơ tài khoản</h2>
                </div>
                <a asp-controller="Account" asp-action="Login" class="rounded-full border border-slate-200 px-4 py-2 text-sm font-bold text-slate-600 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950">Đổi tài khoản</a>
            </div>

            <dl class="mt-6 grid gap-4 sm:grid-cols-2">
                <div class="rounded-3xl bg-slate-50 p-4">
                    <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Email</dt>
                    <dd class="mt-2 font-bold text-slate-950">@Model.Email</dd>
                </div>
                <div class="rounded-3xl bg-slate-50 p-4">
                    <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Số điện thoại</dt>
                    <dd class="mt-2 font-bold text-slate-950">@Model.Phone</dd>
                </div>
                <div class="rounded-3xl bg-slate-50 p-4 sm:col-span-2">
                    <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Địa chỉ</dt>
                    <dd class="mt-2 font-bold text-slate-950">@Model.Address</dd>
                </div>
                <div class="rounded-3xl bg-slate-50 p-4">
                    <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Ngày tham gia</dt>
                    <dd class="mt-2 font-bold text-slate-950">@Model.JoinedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
                <div class="rounded-3xl bg-slate-50 p-4">
                    <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Đăng nhập gần nhất</dt>
                    <dd class="mt-2 font-bold text-slate-950">@Model.LastLoginAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </div>
            </dl>
        </article>

        <aside class="space-y-5">
            <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Tổng quan</p>
                <div class="mt-5 grid gap-3">
                    <div class="rounded-3xl bg-slate-50 p-4">
                        <p class="text-3xl font-black text-slate-950">@Model.TotalOrders</p>
                        <p class="mt-1 text-sm text-slate-500">đơn hàng</p>
                    </div>
                    <div class="rounded-3xl bg-slate-50 p-4">
                        <p class="text-3xl font-black text-brand-700">@Model.TotalSpent.ToString("N0") VND</p>
                        <p class="mt-1 text-sm text-slate-500">tổng chi tiêu</p>
                    </div>
                </div>
            </article>

            <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Trạng thái</p>
                <div class="mt-4 rounded-3xl bg-emerald-50 p-4 text-sm font-bold text-emerald-700">@Model.Status</div>
            </article>
        </aside>
    </section>

    <section class="grid gap-5 lg:grid-cols-2">
        <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Quyền sử dụng</p>
            <h2 class="mt-2 text-2xl font-black text-slate-950">Phân quyền hiện tại</h2>
            <ul class="mt-6 space-y-3">
                @foreach (var permission in Model.Permissions)
                {
                    <li class="flex gap-3 rounded-3xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
                        <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500 text-xs font-black text-white">✓</span>
                        @permission
                    </li>
                }
            </ul>
        </article>

        <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Hoạt động</p>
            <h2 class="mt-2 text-2xl font-black text-slate-950">Gần đây</h2>
            <ol class="mt-6 space-y-3">
                @foreach (var activity in Model.RecentActivities)
                {
                    <li class="rounded-3xl border border-slate-200 bg-white p-4 text-sm font-semibold leading-6 text-slate-700 shadow-sm">@activity</li>
                }
            </ol>
        </article>
    </section>
</div>

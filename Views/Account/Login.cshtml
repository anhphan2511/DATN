@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="grid min-h-[calc(100vh-14rem)] overflow-hidden rounded-[2.5rem] border border-slate-200 bg-white shadow-sm lg:grid-cols-[0.95fr_1.05fr]">
    <div class="relative hidden bg-slate-950 p-10 text-white lg:flex lg:flex-col lg:justify-between">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_18%,rgba(20,184,106,0.35),transparent_28%),radial-gradient(circle_at_88%_78%,rgba(255,255,255,0.14),transparent_24%)]"></div>
        <div class="relative">
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 text-lg font-black">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-sm font-black text-slate-950">D</span>
                DATN Wear
            </a>
            <h1 class="mt-16 max-w-md text-5xl font-black tracking-[-0.05em]">Chào mừng bạn quay lại.</h1>
            <p class="mt-5 max-w-md text-sm leading-7 text-slate-300">
                Đăng nhập để theo dõi đơn hàng, lưu địa chỉ giao hàng và nhận ưu đãi riêng cho thành viên.
            </p>
        </div>
        <div class="relative grid gap-3 sm:grid-cols-3">
            <div class="rounded-3xl border border-white/10 bg-white/10 p-4 backdrop-blur">
                <p class="text-2xl font-black">7 ngày</p>
                <p class="mt-1 text-xs text-slate-300">đổi size</p>
            </div>
            <div class="rounded-3xl border border-white/10 bg-white/10 p-4 backdrop-blur">
                <p class="text-2xl font-black">499K</p>
                <p class="mt-1 text-xs text-slate-300">freeship</p>
            </div>
            <div class="rounded-3xl border border-white/10 bg-white/10 p-4 backdrop-blur">
                <p class="text-2xl font-black">24/7</p>
                <p class="mt-1 text-xs text-slate-300">hỗ trợ</p>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-center p-6 sm:p-10 lg:p-14">
        <div class="w-full max-w-md">
            <div>
                <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Tài khoản</p>
                <h2 class="mt-3 text-4xl font-black tracking-tight text-slate-950">Đăng nhập</h2>
                <p class="mt-3 text-sm leading-6 text-slate-500">Nhập thông tin tài khoản để tiếp tục mua sắm tại DATN Wear.</p>
            </div>

            <form class="mt-8 space-y-5" method="post" action="#">
                <div>
                    <label for="email" class="text-sm font-bold text-slate-700">Email</label>
                    <input id="email" name="email" type="email" autocomplete="email" placeholder="email@example.com" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                </div>

                <div>
                    <div class="flex items-center justify-between gap-4">
                        <label for="password" class="text-sm font-bold text-slate-700">Mật khẩu</label>
                        <a href="#" class="text-sm font-bold text-brand-700 transition hover:text-brand-600">Quên mật khẩu?</a>
                    </div>
                    <input id="password" name="password" type="password" autocomplete="current-password" placeholder="Nhập mật khẩu" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                </div>

                <label class="flex items-center gap-3 text-sm font-semibold text-slate-600">
                    <input type="checkbox" name="rememberMe" class="h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                    Ghi nhớ đăng nhập
                </label>

                <button type="submit" class="w-full rounded-full bg-slate-950 px-6 py-4 text-sm font-black text-white transition hover:bg-brand-700">Đăng nhập</button>
            </form>

            <div class="mt-6 rounded-3xl bg-slate-50 p-4 text-sm text-slate-600">
                Chưa có tài khoản?
                <a asp-controller="Account" asp-action="Register" class="font-black text-brand-700 transition hover:text-brand-600">Đăng ký ngay</a>
            </div>

            <div class="mt-4 rounded-3xl border border-dashed border-slate-300 bg-white p-4">
                <p class="text-sm font-black text-slate-950">Tài khoản demo</p>
                <div class="mt-3 grid gap-2 sm:grid-cols-2">
                    <a asp-controller="Account" asp-action="Details" asp-route-type="customer" class="rounded-2xl bg-brand-50 px-4 py-3 text-sm font-bold text-brand-700 transition hover:bg-brand-100">Xem khách hàng</a>
                    <a asp-controller="Account" asp-action="Details" asp-route-type="admin" class="rounded-2xl bg-slate-950 px-4 py-3 text-sm font-bold text-white transition hover:bg-brand-700">Xem admin</a>
                </div>
                <p class="mt-3 text-xs leading-5 text-slate-500">Hai liên kết này dùng mock data, chưa phải đăng nhập thật.</p>
            </div>
        </div>
    </div>
</section>

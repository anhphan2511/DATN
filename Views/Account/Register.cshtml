@{
    ViewData["Title"] = "Đăng ký";
}

<section class="grid min-h-[calc(100vh-14rem)] overflow-hidden rounded-[2.5rem] border border-slate-200 bg-white shadow-sm lg:grid-cols-[1.05fr_0.95fr]">
    <div class="flex items-center justify-center p-6 sm:p-10 lg:p-14">
        <div class="w-full max-w-xl">
            <div>
                <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-700">Thành viên mới</p>
                <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">Tạo tài khoản DATN Wear</h1>
                <p class="mt-3 text-sm leading-6 text-slate-500">Đăng ký để đặt hàng nhanh hơn, lưu địa chỉ giao hàng và nhận ưu đãi dành riêng cho thành viên.</p>
            </div>

            <form class="mt-8 space-y-5" method="post" action="#">
                <div class="grid gap-5 sm:grid-cols-2">
                    <div>
                        <label for="fullName" class="text-sm font-bold text-slate-700">Họ và tên</label>
                        <input id="fullName" name="fullName" type="text" autocomplete="name" placeholder="Nguyễn Văn A" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                    </div>
                    <div>
                        <label for="phone" class="text-sm font-bold text-slate-700">Số điện thoại</label>
                        <input id="phone" name="phone" type="tel" autocomplete="tel" placeholder="0900 000 000" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                    </div>
                </div>

                <div>
                    <label for="email" class="text-sm font-bold text-slate-700">Email</label>
                    <input id="email" name="email" type="email" autocomplete="email" placeholder="email@example.com" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                </div>

                <div class="grid gap-5 sm:grid-cols-2">
                    <div>
                        <label for="password" class="text-sm font-bold text-slate-700">Mật khẩu</label>
                        <input id="password" name="password" type="password" autocomplete="new-password" placeholder="Tối thiểu 8 ký tự" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                    </div>
                    <div>
                        <label for="confirmPassword" class="text-sm font-bold text-slate-700">Nhập lại mật khẩu</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" placeholder="Nhập lại mật khẩu" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-4 focus:ring-brand-500/15" />
                    </div>
                </div>

                <label class="flex items-start gap-3 text-sm leading-6 text-slate-600">
                    <input type="checkbox" name="acceptPolicy" class="mt-1 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                    <span>Tôi đồng ý với chính sách bảo mật, điều khoản mua hàng và nhận thông tin ưu đãi từ DATN Wear.</span>
                </label>

                <button type="submit" class="w-full rounded-full bg-slate-950 px-6 py-4 text-sm font-black text-white transition hover:bg-brand-700">Tạo tài khoản</button>
            </form>

            <div class="mt-6 rounded-3xl bg-slate-50 p-4 text-sm text-slate-600">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login" class="font-black text-brand-700 transition hover:text-brand-600">Đăng nhập</a>
            </div>
        </div>
    </div>

    <div class="relative hidden bg-gradient-to-br from-slate-950 via-slate-900 to-brand-700 p-10 text-white lg:block">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_76%_18%,rgba(255,255,255,0.2),transparent_24%),radial-gradient(circle_at_20%_88%,rgba(20,184,106,0.32),transparent_28%)]"></div>
        <div class="relative flex h-full flex-col justify-between">
            <div>
                <p class="inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-brand-100 backdrop-blur">Ưu đãi thành viên</p>
                <h2 class="mt-8 max-w-md text-5xl font-black tracking-[-0.05em]">Nhận voucher 100.000 VND cho đơn đầu tiên.</h2>
                <p class="mt-5 max-w-md text-sm leading-7 text-slate-200">Thành viên mới được cập nhật hàng mới, khuyến mãi riêng và theo dõi đơn hàng dễ dàng hơn.</p>
            </div>

            <div class="rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur">
                <p class="text-sm font-bold text-brand-100">Quyền lợi nổi bật</p>
                <div class="mt-4 grid gap-3">
                    <div class="rounded-2xl bg-white/10 p-4 text-sm font-semibold">Lưu nhiều địa chỉ giao hàng</div>
                    <div class="rounded-2xl bg-white/10 p-4 text-sm font-semibold">Theo dõi lịch sử mua hàng</div>
                    <div class="rounded-2xl bg-white/10 p-4 text-sm font-semibold">Nhận thông báo bộ sưu tập mới</div>
                </div>
            </div>
        </div>
    </div>
</section>
